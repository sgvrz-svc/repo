<dict>
	<key>PayloadDisplayName</key>			<string>Disable Camera</string>

	<key>PayloadIdentifier</key>			<string>com.apple.ios.core.camera</string>
	<key>PayloadUUID</key>					<string>AABBCCDD-0030-EEFF-0000-ABCDEF000000</string>
